<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@drawable/widget_bg" android:padding="13dp">
    <TextView android:id="@+id/widget_station" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="r4dio" android:textColor="@color/bright" android:textSize="13sp" android:textStyle="bold"
        android:maxLines="1" android:ellipsize="end" />
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="9dp">
        <TextView android:id="@+id/widget_shuffle" android:layout_width="0dp" android:layout_height="34dp"
            android:layout_weight="1" android:gravity="center" android:text="⇄ SHUFFLE"
            android:textColor="@color/bg" android:textStyle="bold" android:textSize="11sp" android:background="@color/amber_hi" />
        <ImageButton android:id="@+id/widget_toggle" android:layout_width="34dp" android:layout_height="34dp"
            android:layout_marginStart="7dp" android:src="@drawable/ic_play" android:background="@color/panel"
            android:tint="@color/bright" android:contentDescription="play" />
    </LinearLayout>
</LinearLayout>
